# ---------------------------
# Core app settings
# ---------------------------
# Set to "production" on Render
ENVIRONMENT=development

# Comma-separated list of allowed origins for browsers.
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------
# Auth / JWT
# ---------------------------
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256

# Access tokens should be short-lived in production.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh tokens should be longer-lived.
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------
# Database
# ---------------------------
# Dev default can be SQLite; production should be Postgres.
# Render Postgres provides something like:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./payment_system.db

# ---------------------------
# Blockchain (Sepolia)
# ---------------------------
# Public RPC URL example: https://sepolia.infura.io/v3/<key> OR Alchemy URL.
SEPOLIA_RPC_URL=

# Optional: contract details if you store tx hashes on-chain
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CONTRACT_ABI_PATH=blockchain/contracts/abi.json

# Optional: if your backend submits on-chain txs (highly sensitive)
WALLET_PRIVATE_KEY=

