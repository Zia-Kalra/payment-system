# =========================================================
# PAYMENT SYSTEM - ENVIRONMENT TEMPLATE
# =========================================================
# Copy this file to `.env` locally (never commit real secrets).
#
# For production:
# - Render environment variables are set in the Render dashboard.
# - Vercel environment variables are set in the Vercel dashboard.
#
# NOTES:
# - Backend uses standard env var names (no prefix).
# - Frontend (Vite) ONLY exposes env vars that start with VITE_.

# ---------------------------
# Backend (FastAPI) variables
# ---------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated list of allowed browser origins (CORS)
CORS_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite in dev, Postgres in prod)
DATABASE_URL=sqlite:///./backend/payment_system.db

# Blockchain (Sepolia)
SEPOLIA_RPC_URL=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_CONTRACT_ABI_PATH=blockchain/contracts/abi.json
WALLET_PRIVATE_KEY=

# ---------------------------
# Frontend (Vite) variables
# ---------------------------
# If true: frontend uses localStorage mock API (no backend required)
VITE_API_MOCK=true

# Backend base URL for real API calls (used when VITE_API_MOCK=false)
VITE_API_BASE_URL=http://localhost:8000

